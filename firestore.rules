rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==================== USUARIOS ====================
    // Cada usuario solo puede leer/escribir su propio documento
    match /usuarios/{uid} {
      allow read: if request.auth.uid == uid || 
                     get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
      allow write: if request.auth.uid == uid || 
                      get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
      
      // Preferencias (tema, colores)
      match /preferencias/{document=**} {
        allow read, write: if request.auth.uid == uid || 
                              get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
      }
    }

    // ==================== PRE-CLIENTES ====================
    // Temporalmente permitir todo para depuración
    match /pre-clientes/{docId} {
      allow read, write, create, update, delete: if true;
    }

    // ==================== CLIENTES ====================
    // Admin puede ver todos, clientes ven solo el suyo
    match /clientes/{uid} {
      allow read: if request.auth.uid == uid || 
                     get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
      allow write: if request.auth.uid == uid || 
                      get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
    }

    // ==================== TIENDAS ====================
    // El propietario y admin pueden acceder
    match /tiendas/{tiendaId} {
      allow read: if request.auth.uid == resource.data.ownerId || 
                     get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
      allow update, delete: if request.auth.uid == resource.data.ownerId || 
                              get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
      
      // Productos dentro de tiendas
      match /productos/{productoId} {
        allow read: if request.auth.uid == get(/databases/$(database)/documents/tiendas/$(tiendaId)).data.ownerId || 
                       get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
        allow write: if request.auth.uid == get(/databases/$(database)/documents/tiendas/$(tiendaId)).data.ownerId || 
                        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
      }
    }

    
    // ==================== CATEGORÍAS ====================
    // Todos autenticados pueden leer, admin y propietario pueden escribir
    match /categorias/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == resource.data.usuarioId || 
                     get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
      allow create: if request.auth != null && request.auth.uid == request.resource.data.usuarioId;
    }

    // ==================== ÓRDENES ====================
    // Propietario de tienda, cliente y admin
    match /ordenes/{docId} {
      allow read: if request.auth.uid == resource.data.usuarioId || 
                     request.auth.uid == resource.data.ownerId ||
                     get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
      allow write: if request.auth.uid == resource.data.usuarioId || 
                      request.auth.uid == resource.data.ownerId ||
                      get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
    }

    // ==================== BODEGAS ====================
    // Temporalmente permitir todo para depuración
    match /bodegas/{docId} {
      allow read, write, create, update, delete: if true;
    }

    // ==================== MARCAS ====================
    // Temporalmente permitir todo para depuración
    match /marcas/{docId} {
      allow read, write, create, update, delete: if true;
    }

    // ==================== PRODUCTOS ====================
    // El propietario de la tienda y admin (versión mejorada)
    match /productos/{productoId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && 
                       request.auth.uid == request.resource.data.usuarioId;
      allow update, delete: if request.auth.uid == resource.data.usuarioId || 
                              get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
    }

    // ==================== CARRITO ====================
    // Cada usuario solo su carrito
    match /carrito/{uid} {
      allow read, write: if request.auth.uid == uid;
    }

    // ==================== BLOGS DENTRO DE PRE-CLIENTES ====================
    match /pre-clientes/{documento} {
      // Permitir lectura de blogs publicados para cualquier usuario autenticado
      allow read: if request.auth != null && 
                       resource.data.type == 'blog' && 
                       resource.data.status == 'published';
      
      // Permitir lectura/escritura de blogs propios para el usuario dueño
      allow read, write: if request.auth != null && 
                            resource.data.type == 'blog' && 
                            resource.data.usuarioId == request.auth.uid;
      
      // Permitir crear blogs propios
      allow create: if request.auth != null && 
                      request.resource.data.type == 'blog' && 
                      request.resource.data.usuarioId == request.auth.uid;
      
      // Permitir actualizar blogs propios
      allow update: if request.auth != null && 
                      resource.data.type == 'blog' && 
                      resource.data.usuarioId == request.auth.uid;
      
      // Permitir eliminar blogs propios
      allow delete: if request.auth != null && 
                      resource.data.type == 'blog' && 
                      resource.data.usuarioId == request.auth.uid;
    }

    // ==================== PERMISOS POR DEFECTO ====================
    // Denegar todo por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
